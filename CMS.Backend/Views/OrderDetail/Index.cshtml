@model IEnumerable<CMS.Data.Entities.OrderDetail>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-dark">CHI TIẾT ĐƠN HÀNG</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Thêm dòng chi tiết
    </a>
</div>

<table class="table table-hover shadow-sm border">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Mã đơn hàng</th>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
            <th style="width:150px">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>#@item.OrderId</td>
                <td>@item.Product?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.UnitPrice.ToString("N0") đ</td>
                <td>@((item.Quantity * item.UnitPrice).ToString("N0")) đ</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Bạn có chắc chắn muốn xóa dòng này?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>