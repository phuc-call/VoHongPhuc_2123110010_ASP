@model CMS.Data.Entities.OrderDetail
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm chi tiết đơn hàng";
}

<div class="card shadow">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">THÊM CHI TIẾT ĐƠN HÀNG</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Đơn hàng:</label>
                <select asp-for="OrderId" class="form-select"
                        asp-items="ViewBag.OrderList">
                    <option value="">-- Chọn đơn hàng --</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Sản phẩm:</label>
                <select asp-for="ProductId" class="form-select"
                        asp-items="ViewBag.ProductList">
                    <option value="">-- Chọn sản phẩm --</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Số lượng:</label>
                <input asp-for="Quantity" class="form-control" type="number" min="1" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Đơn giá (VNĐ):</label>
                <input asp-for="UnitPrice" class="form-control" type="number" min="0" required />
            </div>
            <button type="submit" class="btn btn-success">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>