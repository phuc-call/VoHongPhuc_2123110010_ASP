<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaiCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 10px 20px;
            }

                .sidebar a:hover {
                    background-color: #343a40;
                    color: white;
                }

            .sidebar .active {
                background-color: #0d6efd;
                color: white;
            }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0">
                <div class="p-3 text-center border-bottom border-secondary">
                    <h4 class="text-white">ThaiCMS Admin</h4>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <small class="text-light">
                            Xin chào, <strong>@User.Identity.Name</strong>
                        </small>
                        <br />
                        <a asp-controller="Account" asp-action="Logout"
                           class="btn btn-outline-danger btn-sm mt-2 w-100">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                           class="btn btn-outline-light btn-sm mt-2 w-100">
                            <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                        </a>
                    }
                </div>

                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>
                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-grid"></i> Quản lý Danh mục
                    </a>
                    <a asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-post"></i> Quản lý Bài viết
                    </a>
                    <a asp-controller="User" asp-action="Index">
                        <i class="bi bi-people"></i> Quản lý Thành viên
                    </a>
                    <a asp-controller="ProductCategory" asp-action="Index">
                        <i class="bi bi-grid"></i> Danh mục sản phẩm
                    </a>
                    <a asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Sản phẩm
                    </a>
                    <a asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-people"></i> Khách hàng
                    </a>
                    <a asp-controller="Order" asp-action="Index">
                        <i class="bi bi-grid"></i> Đơn hàng
                    </a>
                    <a asp-controller="OrderDetail" asp-action="Index">
                        <i class="bi bi-grid"></i> Đơn hàng chi tiết
                    </a>
                </div>
            </nav>

            <main class="col-md-9 col-lg-10 ms-sm-auto p-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>