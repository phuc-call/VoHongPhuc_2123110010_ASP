@model CMS.Data.Entities.Product
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sửa sản phẩm";
}

<div class="card shadow">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0">CHỈNH SỬA SẢN PHẨM</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm:</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả:</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Giá (VNĐ):</label>
                        <input asp-for="Price" class="form-control" type="number" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số lượng tồn:</label>
                        <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Danh mục:</label>
                        <select asp-for="CategoryProductId" class="form-select"
                                asp-items="ViewBag.CategoryProductList">
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ảnh mới (để trống nếu không đổi):</label>
                        <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="img-thumbnail mt-2" style="height:80px" />
                        }
                    </div>
                    <button type="submit" class="btn btn-warning w-100">Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary w-100 mt-2">Quay lại</a>
                </div>
            </div>
        </form>
    </div>
</div>