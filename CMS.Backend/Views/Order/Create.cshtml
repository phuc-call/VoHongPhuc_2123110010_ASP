@model CMS.Data.Entities.Order
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Tạo đơn hàng";
}

<div class="card shadow">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">TẠO ĐƠN HÀNG MỚI</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Khách hàng:</label>
                <select asp-for="CustomerId" class="form-select"
                        asp-items="ViewBag.CustomerList">
                    <option value="">-- Chọn khách hàng --</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Trạng thái:</label>
                <select asp-for="Status" class="form-select">
                    <option value="0">Chờ duyệt</option>
                    <option value="1">Đang giao</option>
                    <option value="2">Đã xong</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Ghi chú:</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-success">Lưu đơn hàng</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>