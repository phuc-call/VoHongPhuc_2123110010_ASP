@model IEnumerable<CMS.Data.Entities.Order>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="text-dark">DANH SÁCH ĐƠN HÀNG</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Tạo đơn hàng
    </a>
</div>

<table class="table table-hover shadow-sm border">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Ngày đặt</th>
            <th>Khách hàng</th>
            <th>Trạng thái</th>
            <th>Ghi chú</th>
            <th style="width:150px">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.OrderDate.ToString("dd/MM/yyyy")</td>
                <td>@item.Customer?.FullName</td>
                <td>
                    @if (item.Status == 0)
                    {
                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                    }
                    else if (item.Status == 1)
                    {
                        <span class="badge bg-primary">Đang giao</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Đã xong</span>
                    }
                </td>
                <td>@item.Notes</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này?')">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>